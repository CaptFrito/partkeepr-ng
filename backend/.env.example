# partkeepr-ng backend — environment variables.
#
# Copy this file to backend/.env and fill in real values. The .env file
# is gitignored; this template is checked in so contributors can see
# the complete contract.

# ---- Required ------------------------------------------------------------

# Database connection. MariaDB 10.6+ recommended (the upstream 1.4.0
# 10.1 dump still imports, but runtime queries require 10.6+).
DATABASE_URL=mysql://partkeepr_dev:partkeepr_dev@127.0.0.1:3306/partkeepr_dev

# HMAC key for signing session cookies. At least 16 characters; rotate
# to invalidate every active session.
#   openssl rand -base64 48
PARTKEEPR_SESSION_SECRET=

# ---- Optional — server tuning --------------------------------------------

BIND_ADDR=127.0.0.1:8080
RUST_LOG=info,partkeepr_api=debug,tower_http=debug

# Path to the static Webix frontend tree. Defaults to "../frontend"
# (matches the dev checkout when run from backend/).
# PARTKEEPR_FRONTEND_DIR=/usr/share/partkeepr-ng/frontend

# File storage root for uploaded attachments + images. Defaults to
# ~/.local/share/partkeepr-ng/files/ for dev.
# PARTKEEPR_STORAGE_DIR=/var/lib/partkeepr-ng/files

# ---- Optional — feature integrations -------------------------------------
# Each setting below enables an optional feature. Leave unset to keep
# the feature disabled; the app starts cleanly without any of them.

# Upload virus scanning via clamd TCP socket. Unset = scanning bypass
# with WARN log. Set + unreachable = uploads fail closed.
# PARTKEEPR_CLAMD=tcp://127.0.0.1:3310

# Label printing (Brother PT-D410 via ptouch-print). Path to the
# binary; unset = "🖨 Label" button hidden.
# PARTKEEPR_PTOUCH_BIN=/usr/bin/ptouch-print

# Mouser Search API key. Unset = "🔎 Add via Mouser" hidden.
# PARTKEEPR_MOUSER_SEARCH_KEY=

# Mouser Order History API key (distinct from the Search key). Unset =
# 📦 Receive Order disabled for Mouser orders.
# PARTKEEPR_MOUSER_ORDER_KEY=

# Digi-Key OAuth2 client credentials. Both required to enable Digi-Key.
# PARTKEEPR_DIGIKEY_CLIENT_ID=
# PARTKEEPR_DIGIKEY_CLIENT_SECRET=

# Digi-Key customer ID — required for OrderStatus calls only (search
# and import work without it). Find it on any Digi-Key order page.
# PARTKEEPR_DIGIKEY_CUSTOMER_ID=

# Digi-Key API base URL override. Defaults to api.digikey.com;
# sandbox is sandbox-api.digikey.com.
# PARTKEEPR_DIGIKEY_BASE_URL=https://api.digikey.com

# Digi-Key Order Status path override. Defaults to
# /orderstatus/v4/salesorder. Override if DK sunsets v4.
# PARTKEEPR_DIGIKEY_ORDER_STATUS_PATH=

# TrustedParts.com Inventory API V2 — live cross-distributor compare
# (ECIA-backed authorized-distributor aggregator). Unset = "💲 Compare
# distributors" button hidden. Results are NOT persisted (TOS forbids
# storage >7 days). Request access at trustedparts.com → My Account →
# Additional Features → Inventory API.
# PARTKEEPR_TRUSTEDPARTS_API_KEY=
# PARTKEEPR_TRUSTEDPARTS_BASE_URL=https://api.trustedparts.com
